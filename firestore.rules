rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Pillars & Helpers
    function isSignedIn() { return request.auth != null; }
    // Note: Relaxed isVerified to just isSignedIn for better compatibility
    function isVerified() { return isSignedIn(); }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'samubaseserratalhadausa@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'coordenacao')
      );
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Users ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['name', 'role']) &&
               data.name is string && data.name.size() <= 100 &&
               data.role is string;
      }

      allow get: if isSignedIn();
      allow list: if isSignedIn();
      
      allow create: if isOwner(userId) && isValidUser(incoming()) && (
        incoming().role != 'coordenacao' || 
        // Allow first user or bootstrap admin if needed
        !exists(/databases/$(database)/documents/users/$(userId)) 
      );
      
      allow update: if isOwner(userId) && 
                    isValidUser(incoming()) &&
                     incoming().diff(existing()).affectedKeys().hasOnly(['name', 'registration', 'cargo', 'base', 'cpf', 'coren', 'role', 'updatedAt', 'lastLogin']) &&
                    (incoming().role == existing().role || isAdmin());

      allow delete: if isAdmin();
    }

    // --- Permutas ---
    match /permutas/{permutaId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // --- Checklists (Materials) ---
    match /checklists/{checklistId} {
      allow read, list, create, update, delete: if isSignedIn();
    }

    // --- Vehicle Checklists ---
    match /vehicle_checklists/{vChecklistId} {
      allow read, list, create, update, delete: if isSignedIn();
    }

    // --- Notifications ---
    match /notifications/{notifId} {
      allow read, list, create, update, delete: if isSignedIn();
    }

    // --- Settings / Config ---
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /config/{configId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
